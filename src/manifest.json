{
  "manifest_version": 3,
  "name": "LexiEng — English Reader",
  "short_name": "LexiEng",
  "version": "0.3.0",
  "description": "JitenReader-style English immersion reading with local dictionaries, frequency filtering, and Anki FSRS reviews.",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LexiEng",
    "default_popup": "pages/widget.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },
  "commands": {
    "parse-page": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Parse the current page with LexiEng"
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "styles/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
